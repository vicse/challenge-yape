{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "apps/card-issuer/src",
  "entryFile": "infrastructure/nestjs/main",
  "compilerOptions": {
    "deleteOutDir": true,
    "webpack": true,
    "tsConfigPath": "apps/card-issuer/tsconfig.app.json"
  },
  "monorepo": true,
  "root": "apps/card-issuer",
  "projects": {
    "card-issuer": {
      "type": "application",
      "root": "apps/card-issuer",
      "entryFile": "infrastructure/nestjs/main",
      "sourceRoot": "apps/card-issuer/src",
      "compilerOptions": {
        "tsConfigPath": "apps/card-issuer/tsconfig.app.json"
      }
    },
    "card-processor": {
      "type": "application",
      "root": "apps/card-processor",
      "entryFile": "infrastructure/nestjs/main",
      "sourceRoot": "apps/card-processor/src",
      "compilerOptions": {
        "tsConfigPath": "apps/card-processor/tsconfig.app.json"
      }
    },
    "cards": {
      "type": "library",
      "root": "libs/cards",
      "entryFile": "index",
      "sourceRoot": "libs/cards/src",
      "compilerOptions": {
        "tsConfigPath": "libs/cards/tsconfig.lib.json"
      }
    },
    "shared": {
      "type": "library",
      "root": "libs/shared",
      "entryFile": "index",
      "sourceRoot": "libs/shared/src",
      "compilerOptions": {
        "tsConfigPath": "libs/shared/tsconfig.lib.json"
      }
    }
  }
}
